---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import MobileNav from '../components/MobileNav.astro';
import SearchOverlay from '../components/SearchOverlay.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'The unofficial field guide to cooking with Costco groceries. Hundreds of recipes with Costco shopping lists and cost-per-serving breakdowns.', ogImage } = Astro.props;
const ogImageUrl = ogImage ? `https://bulk.recipes${ogImage}` : 'https://bulk.recipes/og-default.png';
---

<!--

    ____        _ _                    _
   | __ ) _   _| | | __  _ __ ___  ___(_)_ __   ___  ___
   |  _ \| | | | | |/ / | '__/ _ \/ __| | '_ \ / _ \/ __|
   | |_) | |_| | |   <  | | |  __/ (__| | |_) |  __/\__ \
   |____/ \__,_|_|_|\_\ |_|  \___|\___|_| .__/ \___||___/
                                         |_|

   Hey there, fellow source-code spelunker!
   You found the secret aisle. No membership required.

   We're open source: https://github.com/rbrents3000/bulk.recipes
   Wanna contribute a recipe? PRs welcome.

-->
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#ba0027" />
    <meta name="google-site-verification" content="1q5gzGIbArd3ZIZFr4EFCxlSj_-jNuATGgJuQa60110" />
    <meta name="description" content={description} />
    <link rel="canonical" href={Astro.url.href} />
    <link rel="alternate" type="application/rss+xml" title="bulk.recipes" href="/rss.xml" />
    <link rel="author" href="/humans.txt" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="bulk.recipes" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="bulk.recipes — The unofficial field guide to cooking with Costco groceries" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="bulk.recipes — The unofficial field guide to cooking with Costco groceries" />

    <meta name="generator" content={Astro.generator} />

    <!-- Organization structured data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "bulk.recipes",
      "url": "https://bulk.recipes",
      "logo": "https://bulk.recipes/apple-touch-icon.png",
      "description": "The unofficial field guide to cooking with Costco groceries."
    })} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Critical font: headline (above the fold) -->
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" crossorigin="anonymous" />

    <!-- Deferred fonts: body text + icons -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" crossorigin="anonymous" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" crossorigin="anonymous" /></noscript>

    <!-- Material Icons (deferred — large variable font) -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" media="print" onload="this.media='all'" crossorigin="anonymous" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" crossorigin="anonymous" /></noscript>

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TEBNP70KDY"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-TEBNP70KDY');
    </script>

    <ClientRouter />
    <title>{title}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-primary focus:text-white focus:px-4 focus:py-2 focus:rounded-full focus:font-bold">Skip to main content</a>
    <Navigation />

    <main id="main" class="flex-1 pt-24 pb-36 md:pb-0 px-4 md:px-8 max-w-7xl mx-auto w-full">
      <slot />
    </main>

    <Footer />
    <MobileNav />
    <SearchOverlay />

    <script>
      // Scroll reveal: observe .reveal elements and add .revealed on viewport entry
      const revealObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('revealed');
            revealObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => revealObserver.observe(el));

      // Re-observe after Astro page transitions
      document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('.reveal:not(.revealed), .reveal-stagger:not(.revealed)').forEach(el => revealObserver.observe(el));
      });
    </script>

    <script>
      // Image fallback: replace broken images with data-fallback src
      document.querySelectorAll('img[data-fallback]').forEach(img => {
        img.addEventListener('error', function handler() {
          const el = this as HTMLImageElement;
          const fallback = el.dataset.fallback;
          if (fallback && el.src !== fallback) {
            el.src = fallback;
            // If fallback also fails, hide image and show container bg
            el.addEventListener('error', () => { el.style.display = 'none'; }, { once: true });
          } else {
            el.style.display = 'none';
          }
          el.removeEventListener('error', handler);
        });
      });
    </script>

    <script>
      // Console receipt
      console.log(
        '%c' +
        '┌─────────────────────────────┐\n' +
        '│      BULK.RECIPES           │\n' +
        '│   "The Costco Cookbook"      │\n' +
        '│                             │\n' +
        '│  1x  Good Taste      $0.00  │\n' +
        '│  1x  Open Source     $0.00  │\n' +
        '│  99x Free Samples    $0.00  │\n' +
        '│─────────────────────────────│\n' +
        '│  TOTAL               $0.00  │\n' +
        '│                             │\n' +
        '│  MEMBER #: view-source      │\n' +
        '│  Thank you for snooping!    │\n' +
        '│                             │\n' +
        '│  github.com/rbrents3000/   │\n' +
        '│       bulk.recipes          │\n' +
        '└─────────────────────────────┘',
        'font-family: monospace; font-size: 12px; color: #ba0027;'
      );

      // Konami code: up up down down left right left right b a
      const konami = ['ArrowUp','ArrowUp','ArrowDown','ArrowDown','ArrowLeft','ArrowRight','ArrowLeft','ArrowRight','b','a'];
      let konamiPos = 0;
      document.addEventListener('keydown', (e) => {
        if (e.key === konami[konamiPos]) {
          konamiPos++;
          if (konamiPos === konami.length) {
            konamiPos = 0;
            document.body.style.transition = 'transform 0.5s ease';
            document.body.style.transform = 'rotate(360deg)';
            const banner = document.createElement('div');
            banner.textContent = 'Welcome to Costco. I love you.';
            banner.style.cssText = 'position:fixed;top:0;left:0;right:0;padding:16px;background:#ba0027;color:white;text-align:center;font-size:24px;font-weight:bold;z-index:9999;font-family:Plus Jakarta Sans,sans-serif';
            document.body.appendChild(banner);
            setTimeout(() => {
              document.body.style.transform = '';
              banner.remove();
            }, 3000);
          }
        } else {
          konamiPos = e.key === konami[0] ? 1 : 0;
        }
      });
    </script>
  </body>
</html>
