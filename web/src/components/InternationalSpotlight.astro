---
// Static component — no props
---

<section class="bg-inverse-surface text-inverse-on-surface">
  <div class="max-w-7xl mx-auto px-6 md:px-12 py-16 flex flex-col lg:flex-row gap-10 items-center">
    <!-- Left: Image -->
    <div class="w-full lg:w-1/2 relative rounded-2xl overflow-hidden">
      <div class="h-80 relative">
        <img src="/assets/categories/copycats.webp" alt="International Costco recipes" class="w-full h-full object-cover" loading="lazy" />
        <div class="absolute inset-0 bg-gradient-to-t from-inverse-surface/80 via-inverse-surface/30 to-transparent"></div>
      </div>
    </div>

    <!-- Right: Content -->
    <div class="w-full lg:w-1/2 flex flex-col gap-5">
      <span class="inline-block w-fit px-3 py-1 bg-white/10 text-inverse-on-surface rounded-full text-xs font-black uppercase tracking-wider">
        World of Flavors
      </span>
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tight">
        Explore the Bulk International Aisle
      </h2>
      <p class="text-inverse-on-surface/70 text-base leading-relaxed font-body max-w-lg">
        From Korean BBQ to Italian classics, discover how to recreate authentic international flavors using
        ingredients from the bulk aisle. Big portions, bold taste, budget-friendly prices.
      </p>
      <div>
        <a
          href="/recipes?category=costco-copycats/international"
          class="inline-flex items-center gap-2 bg-primary text-white font-headline font-bold rounded-full px-8 py-3 hover:bg-primary/90 transition-colors shadow-lg hover:shadow-xl"
        >
          Explore Recipes
          <span class="material-symbols-outlined text-lg" aria-hidden="true">arrow_forward</span>
        </a>
      </div>
    </div>
  </div>
</section>
