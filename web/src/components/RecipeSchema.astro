---
interface Props {
  title: string;
  description: string;
  prep: string;
  cook: string;
  servings: string;
  cost: number;
  costUnit: string;
  category: string;
  slug: string;
  ingredients: string[];
  instructions: string[];
  keywords: string;
  nutrition?: { calories: number; protein: number; carbs: number; fat: number };
}

const { title, description, prep, cook, servings, cost, costUnit, category, slug, ingredients, instructions, keywords, nutrition } = Astro.props;

// Convert "15 min" or "8 hr" to ISO 8601 duration "PT15M" or "PT8H"
function toISO(time: string): string {
  const hrs = time.match(/(\d+)\s*hr/i);
  const mins = time.match(/(\d+)\s*min/i);
  let iso = 'PT';
  if (hrs) iso += hrs[1] + 'H';
  if (mins) iso += mins[1] + 'M';
  return iso === 'PT' ? 'PT0M' : iso;
}

// Parse minutes from time string for totalTime calculation
function parseMinutes(time: string): number {
  const hrs = time.match(/(\d+)\s*hr/i);
  const mins = time.match(/(\d+)\s*min/i);
  let total = 0;
  if (hrs) total += parseInt(hrs[1]) * 60;
  if (mins) total += parseInt(mins[1]);
  return total;
}

function minutesToISO(mins: number): string {
  const h = Math.floor(mins / 60);
  const m = mins % 60;
  let iso = 'PT';
  if (h) iso += h + 'H';
  if (m) iso += m + 'M';
  return iso === 'PT' ? 'PT0M' : iso;
}

const totalMinutes = parseMinutes(prep) + parseMinutes(cook);

// Infer cuisine from category
function inferCuisine(cat: string): string {
  if (cat.includes('international')) {
    if (cat.includes('korean') || slug.includes('korean') || slug.includes('tteokbokki') || slug.includes('gimbap')) return 'Korean';
    if (slug.includes('japanese') || slug.includes('karaage') || slug.includes('gyudon')) return 'Japanese';
    if (slug.includes('french') || slug.includes('quiche')) return 'French';
    if (slug.includes('char-siu') || slug.includes('scallion')) return 'Chinese';
    if (slug.includes('cochinita')) return 'Mexican';
    if (slug.includes('tourtiere')) return 'Canadian';
  }
  if (slug.includes('birria') || slug.includes('carnitas') || slug.includes('taco') || slug.includes('enchilada')) return 'Mexican';
  if (slug.includes('bulgogi') || slug.includes('korean')) return 'Korean';
  if (slug.includes('pad-thai') || slug.includes('thai')) return 'Thai';
  if (slug.includes('tikka') || slug.includes('butter-chicken')) return 'Indian';
  if (slug.includes('italian') || slug.includes('lasagna') || slug.includes('ziti')) return 'Italian';
  return 'American';
}

// Format servings with unit — parse leading integer to avoid "12 (24 pieces) servings"
const servingsNum = parseInt(servings);
const formattedServings = servingsNum ? `${servingsNum} servings` : servings;

const schema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Recipe",
  "name": title,
  "description": description,
  "image": `https://bulk.recipes/og/${slug}.png`,
  "prepTime": toISO(prep),
  "cookTime": toISO(cook),
  "totalTime": minutesToISO(totalMinutes),
  "recipeYield": formattedServings,
  "recipeCategory": category.replace(/[-/]/g, ' '),
  "recipeCuisine": inferCuisine(category),
  "keywords": keywords,
  "author": {
    "@type": "Organization",
    "name": "bulk.recipes",
    "url": "https://bulk.recipes"
  },
  "url": `https://bulk.recipes/recipes/${slug}`,
};

// Add nutrition if available
if (nutrition) {
  schema["nutrition"] = {
    "@type": "NutritionInformation",
    "calories": `${nutrition.calories} calories`,
    "proteinContent": `${nutrition.protein} g`,
    "carbohydrateContent": `${nutrition.carbs} g`,
    "fatContent": `${nutrition.fat} g`,
  };
}

// Only add ingredients if we found any
if (ingredients.length > 0) {
  schema["recipeIngredient"] = ingredients;
}

// Only add instructions if we found any
if (instructions.length > 0) {
  schema["recipeInstructions"] = instructions.map(step => ({
    "@type": "HowToStep",
    "text": step,
  }));
}
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
