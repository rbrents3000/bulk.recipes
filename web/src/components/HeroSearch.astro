---
interface Props {
  recipeCount: number;
}

const { recipeCount } = Astro.props;
---

<section class="px-6 md:px-12 py-16 flex flex-col items-center text-center max-w-7xl mx-auto">
  <h1 class="font-headline text-4xl md:text-5xl lg:text-7xl font-extrabold leading-tight tracking-tight mb-6">
    Feed the <span class="text-primary">whole</span> crew.<br />Without the fuss.
  </h1>

  <form action="/recipes" method="get" class="w-full max-w-2xl flex items-center gap-2 mb-8">
    <div class="relative flex-1">
      <label for="hero-search" class="sr-only">Search recipes</label>
      <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-neutral-400 text-xl" aria-hidden="true">search</span>
      <input
        type="text"
        id="hero-search"
        name="q"
        placeholder={`Search ${recipeCount} recipes...`}
        class="w-full rounded-full pl-12 pr-4 h-14 shadow-lg border-none bg-surface-container-lowest font-body text-base focus:outline-none focus:ring-2 focus:ring-primary/40"
      />
    </div>
    <button
      type="submit"
      class="bg-gradient-to-r from-primary to-primary-container text-on-primary font-headline font-extrabold rounded-full px-8 h-14 shadow-[0_12px_24px_rgba(186,0,39,0.2)] hover:scale-[1.02] active:scale-95 transition-all whitespace-nowrap"
    >
      Find Food
    </button>
  </form>

  <div class="flex flex-wrap items-center justify-center gap-3">
    <a href="/recipes" class="inline-flex items-center gap-1.5 rounded-full bg-secondary-fixed text-on-secondary-fixed px-5 py-2.5 font-body text-sm font-bold shadow-sm hover:shadow-md hover:scale-[1.02] transition-all">
      <span class="material-symbols-outlined text-lg" aria-hidden="true">payments</span>
      Cost
    </a>
    <a href="/recipes" class="inline-flex items-center gap-1.5 rounded-full bg-surface-container-high text-on-surface-variant px-5 py-2.5 font-body text-sm font-bold hover:shadow-md hover:scale-[1.02] transition-all">
      <span class="material-symbols-outlined text-lg" aria-hidden="true">timer</span>
      Cook Time
    </a>
    <a href="/recipes" class="inline-flex items-center gap-1.5 rounded-full bg-surface-container-high text-on-surface-variant px-5 py-2.5 font-body text-sm font-bold hover:shadow-md hover:scale-[1.02] transition-all">
      <span class="material-symbols-outlined text-lg" aria-hidden="true">eco</span>
      Diet
    </a>
    <a href="/recipes" class="inline-flex items-center gap-1.5 rounded-full bg-surface-container-high text-on-surface-variant px-5 py-2.5 font-body text-sm font-bold hover:shadow-md hover:scale-[1.02] transition-all">
      <span class="material-symbols-outlined text-lg" aria-hidden="true">grocery</span>
      Ingredient
    </a>
  </div>
</section>
