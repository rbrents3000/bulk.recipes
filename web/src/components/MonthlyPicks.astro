---
interface Recipe {
  title: string;
  slug: string;
  cost: number;
  cook: string;
  servings: string;
  category: string;
}

interface Props {
  recipes: Recipe[];
}

const { recipes } = Astro.props;

const monthName = new Date().toLocaleString('en-US', { month: 'long' });
---

<section class="px-6 md:px-12 py-16 max-w-7xl mx-auto">
  <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
    <div>
      <span class="inline-block px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full text-xs font-black uppercase tracking-wider mb-3">
        Seasonal Spotlight
      </span>
      <h2 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tight">
        What to Cook This Month ({monthName})
      </h2>
    </div>
    <a
      href={`/recipes?month=${monthName.toLowerCase()}`}
      class="inline-flex items-center gap-1.5 text-primary font-headline font-bold hover:underline whitespace-nowrap"
    >
      View {monthName} Index
      <span class="material-symbols-outlined text-lg" aria-hidden="true">arrow_forward</span>
    </a>
  </div>

  <div class="grid grid-cols-[repeat(auto-fill,minmax(280px,1fr))] gap-6">
    {recipes.map((recipe) => (
      <a href={`/recipes/${recipe.slug}`} class="group block">
        <div class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_8px_32px_rgba(47,47,47,0.04)] hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(47,47,47,0.08)] transition-all duration-300">
          <div class="relative h-64 bg-surface-container flex items-center justify-center overflow-hidden">
            <span class="material-symbols-outlined text-5xl text-on-surface-variant opacity-20" aria-hidden="true">restaurant</span>
            <div class="absolute top-3 right-3">
              <span class="px-3 py-1 bg-tertiary-container text-on-tertiary-container rounded-full text-[10px] font-black uppercase tracking-wider">
                {recipe.cost < 2 ? 'Cheap!' : `${recipe.servings} servings`}
              </span>
            </div>
          </div>
          <div class="p-5">
            <h3 class="font-headline font-bold text-xl mb-2 group-hover:text-primary transition-colors line-clamp-2">
              {recipe.title}
            </h3>
            <div class="flex items-center gap-4 text-sm text-on-surface-variant">
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-base" aria-hidden="true">schedule</span>
                {recipe.cook}
              </span>
              <span class="flex items-center gap-1">
                <span class="material-symbols-outlined text-base" aria-hidden="true">payments</span>
                <span class="font-bold text-tertiary">${recipe.cost.toFixed(2)}</span>
              </span>
            </div>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>
