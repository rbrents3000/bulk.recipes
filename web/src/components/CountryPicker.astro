---
const countries = [
  { iso: 'us', label: 'USA', slug: 'us' },
  { iso: 'ca', label: 'Canada', slug: 'canada' },
  { iso: 'mx', label: 'Mexico', slug: 'mexico' },
  { iso: 'gb', label: 'UK', slug: 'uk' },
  { iso: 'kr', label: 'Korea', slug: 'korea' },
  { iso: 'jp', label: 'Japan', slug: 'japan' },
  { iso: 'au', label: 'Australia', slug: 'australia' },
  { iso: 'es', label: 'Spain', slug: 'spain' },
  { iso: 'fr', label: 'France', slug: 'france' },
  { iso: 'cn', label: 'China', slug: 'china' },
  { iso: 'is', label: 'Iceland', slug: 'iceland' },
  { iso: 'nz', label: 'NZ', slug: 'new-zealand' },
  { iso: 'se', label: 'Sweden', slug: 'sweden' },
  { iso: 'tw', label: 'Taiwan', slug: 'taiwan' },
];
---

<section class="px-6 md:px-12 py-16 max-w-7xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <span class="material-symbols-outlined text-2xl text-primary" aria-hidden="true">public</span>
    <h2 class="font-headline text-2xl md:text-3xl font-bold">What's at YOUR Costco?</h2>
  </div>

  <div class="overflow-x-auto hide-scrollbar -mx-6 px-6">
    <div class="flex gap-4 w-max pb-2">
      {countries.map((country) => (
        <a
          href={`/prepared/${country.slug}`}
          aria-label={`Prepared foods from ${country.label}`}
          class="flex flex-col items-center gap-1.5 min-w-[5rem] rounded-2xl bg-white border border-neutral-200 px-4 py-3 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all"
        >
          <img src={`/assets/flags/${country.iso}.svg`} alt="" class="w-8 h-8" loading="lazy" />
          <span class="font-body text-sm font-medium text-neutral-700">{country.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
