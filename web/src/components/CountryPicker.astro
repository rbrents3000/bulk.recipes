---
const countries = [
  { emoji: '🇺🇸', label: 'USA', slug: 'us' },
  { emoji: '🇨🇦', label: 'Canada', slug: 'canada' },
  { emoji: '🇲🇽', label: 'Mexico', slug: 'mexico' },
  { emoji: '🇬🇧', label: 'UK', slug: 'uk' },
  { emoji: '🇰🇷', label: 'Korea', slug: 'korea' },
  { emoji: '🇯🇵', label: 'Japan', slug: 'japan' },
  { emoji: '🇦🇺', label: 'Australia', slug: 'australia' },
  { emoji: '🇪🇸', label: 'Spain', slug: 'spain' },
  { emoji: '🇫🇷', label: 'France', slug: 'france' },
  { emoji: '🇨🇳', label: 'China', slug: 'china' },
  { emoji: '🇮🇸', label: 'Iceland', slug: 'iceland' },
  { emoji: '🇳🇿', label: 'NZ', slug: 'new-zealand' },
  { emoji: '🇸🇪', label: 'Sweden', slug: 'sweden' },
  { emoji: '🇹🇼', label: 'Taiwan', slug: 'taiwan' },
];
---

<section class="px-6 md:px-12 py-10 max-w-7xl mx-auto">
  <div class="flex items-center gap-2 mb-6">
    <span class="material-symbols-outlined text-2xl text-primary">public</span>
    <h2 class="font-headline text-2xl md:text-3xl font-bold">What's at YOUR Costco?</h2>
  </div>

  <div class="overflow-x-auto hide-scrollbar -mx-6 px-6">
    <div class="flex gap-4 w-max pb-2">
      {countries.map((country) => (
        <a
          href={`/prepared/${country.slug}`}
          class="flex flex-col items-center gap-1.5 min-w-[5rem] rounded-2xl bg-white border border-neutral-200 px-4 py-3 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all"
        >
          <span class="text-3xl">{country.emoji}</span>
          <span class="font-body text-sm font-medium text-neutral-700">{country.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
