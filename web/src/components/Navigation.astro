---
const currentPath = Astro.url.pathname;
---

<nav aria-label="Main navigation" class="fixed top-0 w-full flex justify-between items-center px-6 py-4 max-w-full mx-auto bg-white/80 backdrop-blur-md z-50 shadow-[0_8px_32px_rgba(47,47,47,0.06)]">
  <div class="flex items-center gap-8">
    <a class="text-2xl font-black text-primary italic tracking-tighter font-headline" href="/">
      bulk.recipes
    </a>
    <div class="hidden md:flex items-center gap-6">
      <a
        class:list={[
          "font-headline tracking-tight transition-colors",
          currentPath.startsWith('/recipes') ? "text-primary border-b-4 border-primary pb-1 font-bold" : "text-neutral-600 hover:text-primary font-medium"
        ]}
        href="/recipes"
        aria-current={currentPath.startsWith('/recipes') ? 'page' : undefined}
      >
        Recipes
      </a>
      <a
        class:list={[
          "font-headline tracking-tight transition-colors",
          currentPath.startsWith('/prepared') ? "text-primary border-b-4 border-primary pb-1 font-bold" : "text-neutral-600 hover:text-primary font-medium"
        ]}
        href="/prepared"
        aria-current={currentPath.startsWith('/prepared') ? 'page' : undefined}
      >
        Countries
      </a>
      <a
        class:list={[
          "font-headline tracking-tight transition-colors",
          currentPath.startsWith('/guides') ? "text-primary border-b-4 border-primary pb-1 font-bold" : "text-neutral-600 hover:text-primary font-medium"
        ]}
        href="/guides"
        aria-current={currentPath.startsWith('/guides') ? 'page' : undefined}
      >
        Guides
      </a>
      <a
        class:list={[
          "font-headline tracking-tight transition-colors",
          currentPath.startsWith('/products') ? "text-primary border-b-4 border-primary pb-1 font-bold" : "text-neutral-600 hover:text-primary font-medium"
        ]}
        href="/products"
        aria-current={currentPath.startsWith('/products') ? 'page' : undefined}
      >
        Products
      </a>
    </div>
  </div>
  <div class="flex items-center gap-4">
    <button data-search-trigger class="hover:scale-105 transition-transform duration-200 p-2 rounded-full hover:bg-surface-container flex items-center gap-2" aria-label="Search (Ctrl+K)">
      <span class="material-symbols-outlined text-primary" aria-hidden="true">search</span>
      <kbd class="kbd-shortcut hidden text-[10px] text-on-surface-variant bg-surface-container px-1.5 py-0.5 rounded font-mono"></kbd>
    </button>
  </div>
</nav>

<script>
  const platform = navigator.userAgentData?.platform || navigator.platform || '';
  const isMac = /Mac|iPhone|iPad|iPod/i.test(platform);
  document.querySelectorAll('.kbd-shortcut').forEach(el => {
    el.textContent = isMac ? '⌘K' : 'Ctrl+K';
    if (window.innerWidth >= 1024) el.classList.remove('hidden');
  });
</script>
