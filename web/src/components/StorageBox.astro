---
interface Props {
  storage: string;
}

const { storage } = Astro.props;
---

<div class="bg-tertiary-container/10 p-8 rounded-xl border-l-8 border-tertiary-container">
  <h3 class="text-xl font-bold mb-4 flex items-center gap-2 font-headline">
    <span class="material-symbols-outlined text-tertiary" aria-hidden="true">inventory_2</span>
    Storage & Freezing
  </h3>
  <p class="text-sm leading-relaxed text-on-surface-variant">{storage}</p>
</div>
