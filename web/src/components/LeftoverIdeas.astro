---
interface Props {
  ideas: string[];
}

const { ideas } = Astro.props;

const emojiMap: Record<string, string[]> = {
  '\uD83C\uDF2E': ['taco', 'wrap', 'tortilla', 'burrito', 'quesadilla'],
  '\uD83E\uDD57': ['salad', 'greens', 'slaw'],
  '\uD83C\uDF73': ['breakfast', 'egg', 'omelet', 'frittata', 'morning'],
  '\uD83E\uDD63': ['soup', 'stew', 'broth', 'chili', 'chowder'],
  '\uD83C\uDF55': ['pizza', 'flatbread'],
  '\uD83E\uDD6A': ['sandwich', 'panini', 'sub', 'melt', 'slider'],
  '\uD83C\uDF5A': ['rice', 'bowl', 'grain', 'stir-fry', 'fried rice'],
  '\uD83C\uDF81': ['gift', 'neighbor', 'friend', 'share'],
};

function pickEmoji(text: string): string {
  const lower = text.toLowerCase();
  for (const [emoji, keywords] of Object.entries(emojiMap)) {
    if (keywords.some((kw) => lower.includes(kw))) return emoji;
  }
  return '\uD83D\uDCA1';
}

function parseIdea(raw: string): { emoji: string; title: string; description: string } {
  const colonIdx = raw.indexOf(':');
  if (colonIdx > 0) {
    const title = raw.slice(0, colonIdx).trim();
    const description = raw.slice(colonIdx + 1).trim();
    return { emoji: pickEmoji(raw), title, description };
  }
  return { emoji: pickEmoji(raw), title: raw.trim(), description: '' };
}
---

<div class="bg-surface-container p-10 rounded-xl">
  <h3 class="text-2xl font-extrabold mb-6 font-headline">Leftover Ideas</h3>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {ideas.map((raw) => {
      const { emoji, title, description } = parseIdea(raw);
      return (
        <div class="p-4 bg-surface-container-lowest rounded-lg hover:shadow-lg transition-all cursor-pointer">
          <span class="text-3xl mb-2 block" aria-hidden="true">{emoji}</span>
          <h4 class="font-bold mb-1 font-headline">{title}</h4>
          {description && <p class="text-xs text-on-surface-variant">{description}</p>}
        </div>
      );
    })}
  </div>
</div>
