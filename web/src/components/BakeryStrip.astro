---
import { getCollection } from 'astro:content';

const recipes = await getCollection('recipes');
const bakeryRecipes = recipes
  .filter(r => r.data.category === 'costco-copycats/bakery')
  .slice(0, 3);

const hasContent = bakeryRecipes.length > 0;
const names = bakeryRecipes.map(r => r.data.title);
---

{hasContent && (
  <section class="reveal relative overflow-hidden bg-secondary-container px-6 md:px-12 py-16">
    <!-- Decorative blurred circles -->
    <div class="absolute -top-12 -left-12 w-48 h-48 rounded-full bg-white/20 blur-3xl"></div>
    <div class="absolute -bottom-16 right-8 w-64 h-64 rounded-full bg-tertiary-container/30 blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto flex flex-col md:flex-row items-start md:items-center gap-6">
      <div class="flex-1">
        <span class="inline-block bg-white/40 rounded-full px-4 py-1 font-body text-sm font-semibold text-neutral-800 mb-3">
          Fresh from the Oven
        </span>
        <p class="font-headline text-xl md:text-2xl font-bold text-neutral-900 leading-snug">
          In the bakery right now: {names.map((name, i) => (
            <><span class="text-primary">{name}</span>{i < names.length - 1 ? ', ' : ''}</>
          ))}
        </p>
      </div>

      <div class="flex items-center gap-3 shrink-0">
        <a
          href="/recipes?category=costco-copycats/bakery"
          class="bg-gradient-to-r from-primary to-primary-container text-on-primary font-headline font-extrabold rounded-full px-8 py-3.5 shadow-[0_12px_24px_rgba(186,0,39,0.2)] hover:scale-[1.02] active:scale-95 transition-all"
        >
          Browse Bakery Recipes
        </a>
        <a
          href="/guides"
          class="bg-white text-neutral-800 font-headline font-bold rounded-full px-8 py-3.5 shadow-md hover:shadow-lg hover:scale-[1.02] transition-all"
        >
          Bulk Tips
        </a>
      </div>
    </div>
  </section>
)}
