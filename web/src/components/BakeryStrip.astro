---
---

<section class="relative overflow-hidden bg-secondary-container px-6 md:px-12 py-10">
  <!-- Decorative blurred circles -->
  <div class="absolute -top-12 -left-12 w-48 h-48 rounded-full bg-white/20 blur-3xl"></div>
  <div class="absolute -bottom-16 right-8 w-64 h-64 rounded-full bg-tertiary-container/30 blur-3xl"></div>

  <div class="relative max-w-7xl mx-auto flex flex-col md:flex-row items-start md:items-center gap-6">
    <div class="flex-1">
      <span class="inline-block bg-white/40 rounded-full px-4 py-1 font-body text-sm font-semibold text-neutral-800 mb-3">
        Fresh from the Oven
      </span>
      <p class="font-headline text-xl md:text-2xl font-bold text-neutral-900 leading-snug">
        In the bakery right now: <span class="text-primary">Lemon Custard Pie</span>, <span class="text-primary">Peaches &amp; Cream Pastries</span>
      </p>
    </div>

    <div class="flex items-center gap-3 shrink-0">
      <a
        href="/recipes"
        class="bg-primary text-white font-body font-semibold rounded-full px-6 py-2.5 shadow-md hover:bg-primary/90 transition-colors"
      >
        Grab Recipes
      </a>
      <a
        href="/guides"
        class="bg-white text-neutral-800 font-body font-semibold rounded-full px-6 py-2.5 shadow-md hover:shadow-lg transition-shadow"
      >
        Bulk Tips
      </a>
    </div>
  </div>
</section>
