---
import { getCategoryImage } from '../data/categoryImages';

interface Recipe {
  title: string;
  slug: string;
  description: string;
  cost: number;
  cost_unit: string;
  category: string;
}

interface Props {
  recipes: Recipe[];
}

const { recipes } = Astro.props;

---

<section class="reveal px-6 md:px-12 py-16 max-w-7xl mx-auto">
  <div class="mb-10">
    <div class="h-1 w-12 bg-primary rounded-full mb-4"></div>
    <h2 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tight">
      Top Costco Copycats
    </h2>
  </div>

  <div class="relative">
    <div id="copycats-scroll" class="flex gap-6 overflow-x-auto pb-4 -mx-6 px-6 snap-x snap-mandatory hide-scrollbar">
      {recipes.map((recipe) => (
        <a
          href={`/recipes/${recipe.slug}`}
          class="group min-w-[320px] flex-shrink-0 snap-start"
        >
          <div class="bg-surface-container-lowest rounded-xl overflow-visible shadow-[0_8px_32px_rgba(47,47,47,0.04)] hover:-translate-y-1 hover:shadow-[0_24px_48px_rgba(0,0,0,0.08)] transition-all duration-300">
            <div class="p-3">
              <div class="h-48 w-full rounded-lg overflow-hidden bg-surface-container">
                <img src={`/assets/recipes/${recipe.slug.split('/').pop()}.webp`} alt="" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" aria-hidden="true" loading="lazy" data-fallback={getCategoryImage(recipe.category)} />
              </div>
            </div>
            <div class="px-6 pb-6 pt-2">
              <h3 class="font-headline font-bold text-lg mb-2 group-hover:text-primary transition-colors line-clamp-2">
                {recipe.title}
              </h3>
              <p class="text-sm text-on-surface-variant line-clamp-2 mb-4">
                {recipe.description}
              </p>
              <span class="text-primary font-bold text-sm inline-flex items-center gap-1 group-hover:gap-2 transition-all">
                Get Recipe &rarr;
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
    <div id="copycats-fade-left" class="absolute top-0 left-0 bottom-0 w-16 bg-gradient-to-r from-[#f9f6f5] to-transparent pointer-events-none opacity-0 transition-opacity" aria-hidden="true"></div>
    <div id="copycats-fade-right" class="absolute top-0 right-0 bottom-0 w-16 bg-gradient-to-l from-[#f9f6f5] to-transparent pointer-events-none transition-opacity" aria-hidden="true"></div>
  </div>
</section>

<script>
  const scroller = document.getElementById('copycats-scroll');
  const fadeLeft = document.getElementById('copycats-fade-left');
  const fadeRight = document.getElementById('copycats-fade-right');
  if (scroller && fadeLeft && fadeRight) {
    function updateFades() {
      fadeLeft.style.opacity = scroller.scrollLeft > 10 ? '1' : '0';
      fadeRight.style.opacity = scroller.scrollLeft < scroller.scrollWidth - scroller.clientWidth - 10 ? '1' : '0';
    }
    scroller.addEventListener('scroll', updateFades, { passive: true });
    updateFades();
  }
</script>
