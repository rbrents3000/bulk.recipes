---
interface Recipe {
  title: string;
  slug: string;
  description: string;
  cost: number;
}

interface Props {
  recipes: Recipe[];
}

const { recipes } = Astro.props;
---

<section class="px-6 md:px-12 py-16 max-w-7xl mx-auto">
  <div class="mb-10">
    <div class="h-1 w-12 bg-primary rounded-full mb-4"></div>
    <h2 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tight">
      New this month
    </h2>
  </div>

  <div class="flex gap-6 overflow-x-auto pb-4 -mx-6 px-6 snap-x snap-mandatory hide-scrollbar">
    {recipes.map((recipe) => (
      <a
        href={`/recipes/${recipe.slug}`}
        class="group min-w-[320px] flex-shrink-0 snap-start"
      >
        <div class="bg-white rounded-xl overflow-hidden shadow-md hover:shadow-xl transition-all duration-300">
          <div class="h-48 bg-surface-container flex items-center justify-center">
            <span class="material-symbols-outlined text-5xl text-on-surface-variant opacity-20">restaurant</span>
          </div>
          <div class="p-5">
            <h3 class="font-headline font-bold text-lg mb-2 group-hover:text-primary transition-colors line-clamp-2">
              {recipe.title}
            </h3>
            <p class="text-sm text-outline-variant line-clamp-2 mb-4">
              {recipe.description}
            </p>
            <span class="text-primary font-bold text-sm inline-flex items-center gap-1 group-hover:gap-2 transition-all">
              Get Recipe &rarr;
            </span>
          </div>
        </div>
      </a>
    ))}
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
