---
const navItems = [
  { icon: 'restaurant_menu', label: 'Recipes', href: '/recipes' },
  { icon: 'explore', label: 'Explore', href: '/prepared' },
  { icon: 'calculate', label: 'Calculator', href: '/guides' },
  { icon: 'info', label: 'About', href: '/about' },
];
---

<nav aria-label="Mobile navigation" class="md:hidden fixed bottom-6 left-1/2 -translate-x-1/2 w-[90%] bg-surface-container-lowest/90 backdrop-blur-xl h-16 rounded-full shadow-2xl flex items-center justify-around px-6 z-50">
  {navItems.map((item) => (
    <a
      href={item.href}
      class="mobile-nav-btn flex flex-col items-center justify-center gap-0.5 min-w-[44px] min-h-[44px] text-neutral-500 transition-colors"
      data-href={item.href}
      aria-label={item.label}
    >
      <span class="material-symbols-outlined text-2xl" aria-hidden="true">{item.icon}</span>
      <span class="font-body text-[10px] font-medium">{item.label}</span>
    </a>
  ))}
</nav>

<script>
  document.addEventListener('astro:page-load', highlightNav);
  document.addEventListener('DOMContentLoaded', highlightNav);

  function highlightNav() {
    const path = window.location.pathname;
    document.querySelectorAll('.mobile-nav-btn').forEach((btn) => {
      const href = btn.getAttribute('data-href');
      const isActive = href !== '#' && path.startsWith(href);
      if (isActive) {
        btn.classList.remove('text-neutral-500');
        btn.classList.add('text-primary');
        btn.setAttribute('aria-current', 'page');
      } else {
        btn.classList.remove('text-primary');
        btn.classList.add('text-neutral-500');
        btn.removeAttribute('aria-current');
      }
    });
  }
</script>
