---
interface Props {
  categoryCounts: Record<string, number>;
}

const { categoryCounts } = Astro.props;

const costcoCount = categoryCounts['costco-copycats'] ?? 0;
const weeknightCount = categoryCounts['weeknight-dinners'] ?? 0;
const grillingCount = categoryCounts['grilling'] ?? 0;
const mealPrepCount = categoryCounts['meal-prep'] ?? 0;
---

<section class="reveal px-6 md:px-12 py-16 max-w-7xl mx-auto">
  <h2 class="font-headline text-3xl md:text-4xl font-extrabold tracking-tight mb-10">
    Shop by Vibes
  </h2>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[140px] md:auto-rows-[200px]">
    <!-- Costco Copycats: 2x2 -->
    <a
      href="/recipes?category=costco-copycats"
      class="col-span-2 row-span-2 relative rounded-2xl p-6 overflow-hidden group hover:shadow-xl transition-all duration-300"
    >
      <img src="/assets/categories/copycats.webp" alt="" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/10 group-hover:from-black/80 transition-all duration-300"></div>
      <div class="relative z-10 h-full flex flex-col justify-between">
        <div>
          <h3 class="font-headline font-extrabold text-2xl md:text-3xl text-white mb-1">
            Costco Copycats
          </h3>
          <p class="text-white/70 text-sm font-body">
            {costcoCount} recipes
          </p>
        </div>
        <div class="flex flex-wrap gap-2">
          {['Food Court', 'Deli', 'Bakery', 'International'].map((pill) => (
            <span class="px-3 py-1 bg-white/20 text-white rounded-full text-xs font-bold backdrop-blur-sm">
              {pill}
            </span>
          ))}
        </div>
      </div>
    </a>

    <!-- Weeknight Dinners: 1x1 -->
    <a
      href="/recipes?category=weeknight-dinners"
      class="relative rounded-2xl p-5 overflow-hidden group hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
    >
      <img src="/assets/categories/weeknight.webp" alt="" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/10 group-hover:from-black/80 transition-all duration-300"></div>
      <div class="relative z-10 h-full flex flex-col justify-between">
        <div>
          <h3 class="font-headline font-bold text-lg text-white">Weeknight Dinners</h3>
          <p class="text-white/70 text-sm">{weeknightCount} recipes</p>
        </div>
        <span class="material-symbols-outlined text-white text-2xl" aria-hidden="true">arrow_forward</span>
      </div>
    </a>

    <!-- Grilling: 1x1 -->
    <a
      href="/recipes?category=grilling"
      class="relative rounded-2xl p-5 overflow-hidden group hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
    >
      <img src="/assets/categories/grilling.webp" alt="" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/10 group-hover:from-black/80 transition-all duration-300"></div>
      <div class="relative z-10 h-full flex flex-col justify-between">
        <div>
          <h3 class="font-headline font-bold text-lg text-white">Grilling</h3>
          <p class="text-white/70 text-sm">{grillingCount} recipes</p>
        </div>
        <span class="material-symbols-outlined text-white text-2xl" aria-hidden="true">arrow_forward</span>
      </div>
    </a>

    <!-- Meal Prep: 2x1 -->
    <a
      href="/recipes?category=meal-prep"
      class="col-span-2 relative rounded-2xl p-6 overflow-hidden group hover:shadow-xl hover:-translate-y-1 transition-all duration-300"
    >
      <img src="/assets/categories/meal-prep.webp" alt="" class="absolute inset-0 w-full h-full object-cover" aria-hidden="true" />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-black/10 group-hover:from-black/80 transition-all duration-300"></div>
      <div class="relative z-10 h-full flex flex-col justify-between">
        <div>
          <h3 class="font-headline font-extrabold text-xl md:text-2xl text-white">
            Meal Prep
          </h3>
          <p class="text-white/70 text-sm">{mealPrepCount} recipes</p>
        </div>
        <span class="material-symbols-outlined text-white text-2xl" aria-hidden="true">arrow_forward</span>
      </div>
    </a>
  </div>
</section>
