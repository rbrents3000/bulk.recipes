---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { marked } from 'marked';
import Base from '../../layouts/Base.astro';

export function getStaticPaths() {
  const slugs = [
    'by-country', 'by-ingredient', 'cost-index', 'dietary', 'first-trip',
    'freezer-guide', 'holidays', 'meal-plans', 'party-planning',
    'rotisserie-chicken', 'seasonal', 'whats-in-season',
  ];
  return slugs.map(slug => ({ params: { slug }, props: { slug } }));
}

const { slug } = Astro.props;
let md = readFileSync(join(process.cwd(), '..', 'guides', `${slug}.md`), 'utf-8');

// Auto-rotate the hero section for the "What's In Season" guide
if (slug === 'whats-in-season' && md.includes('<!-- CURRENT_MONTH_HERO -->')) {
  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June',
    'July', 'August', 'September', 'October', 'November', 'December'];
  const monthIds = ['january', 'february', 'march', 'april', 'may', 'june',
    'july', 'august', 'september', 'october', 'november', 'december'];
  const now = new Date();
  const monthName = monthNames[now.getMonth()];
  const monthId = monthIds[now.getMonth()];

  // Extract the current month's section from the full calendar
  const sectionRegex = new RegExp(
    `### ${monthName} \\{#${monthId}\\}\\n([\\s\\S]*?)(?=\\n---)`
  );
  const match = md.match(sectionRegex);

  if (match) {
    const monthContent = match[1].trim();
    const hero = `## Right Now: ${monthName}\n\n${monthContent}\n\n> **Tip:** This section updates each month. The current month gets the hero spot up top, and the full twelve-month archive lives below for planning ahead.`;
    md = md.replace('<!-- CURRENT_MONTH_HERO -->', hero);
  }
}

// Fix relative recipe/guide links to proper routes
md = md.replace(/\(\.\.\/recipes\/([^)]+)\.md\)/g, '(/recipes/$1)');
md = md.replace(/\(([a-z-]+)\.md\)/g, '(/guides/$1)');

const html = marked(md) as string;
const titleMatch = md.match(/^#\s+(.+)/m);
const title = titleMatch ? titleMatch[1] : slug.replace(/-/g, ' ');

// Extract first paragraph as description
const descMatch = md.match(/^(?!#|\||\s*$)(.+)/m);
const description = descMatch ? descMatch[1].replace(/^>\s*/, '').replace(/[*_`\[\]]/g, '').slice(0, 160) : `${title} — a guide for Costco bulk shoppers.`;
---

<Base title={`${title} — bulk.recipes`} description={description}>
  <div class="max-w-4xl mx-auto py-8">
    <a href="/guides" class="inline-flex items-center gap-1 text-sm text-on-surface-variant hover:text-primary transition-colors mb-6">
      <span class="material-symbols-outlined text-sm">arrow_back</span>
      All Guides
    </a>

    <article class="prose prose-lg max-w-none
      prose-headings:font-headline prose-headings:tracking-tight
      prose-h1:text-4xl prose-h1:font-black
      prose-h2:text-2xl prose-h2:font-bold prose-h2:border-b-4 prose-h2:border-primary prose-h2:inline-block prose-h2:pb-1 prose-h2:mt-10 prose-h2:mb-4
      prose-h3:text-xl prose-h3:font-bold prose-h3:mt-8
      prose-p:text-on-surface-variant prose-p:leading-relaxed
      prose-a:text-primary prose-a:no-underline hover:prose-a:underline
      prose-table:text-sm
      prose-th:text-left prose-th:font-bold prose-th:bg-surface-container-low prose-th:p-3
      prose-td:p-3 prose-td:border-b prose-td:border-surface-container
      prose-blockquote:bg-primary-container/10 prose-blockquote:border-l-4 prose-blockquote:border-primary-container prose-blockquote:rounded-r-lg prose-blockquote:py-3 prose-blockquote:px-4 prose-blockquote:not-italic
      prose-strong:text-on-surface
      prose-li:text-on-surface-variant
    " data-pagefind-body>
      <Fragment set:html={html} />
    </article>
  </div>
</Base>
