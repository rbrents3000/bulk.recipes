---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { marked } from 'marked';
import Base from '../../layouts/Base.astro';

const md = readFileSync(join(process.cwd(), '..', 'guides', 'README.md'), 'utf-8');
const rawHtml = marked(md) as string;
// Fix relative .md links to use proper /guides/ routes
const html = rawHtml.replace(/href="([^"]+)\.md"/g, (_match, slug) => `href="/guides/${slug}"`);
---

<Base title="Guides — bulk.recipes" description="Tips, tricks, and strategies for getting the most out of your Costco haul.">
  <article class="max-w-4xl mx-auto py-8 prose prose-lg max-w-none
    prose-headings:font-headline prose-headings:tracking-tight
    prose-h1:text-4xl prose-h1:font-black
    prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-10
    prose-h3:text-xl prose-h3:font-bold prose-h3:mt-8
    prose-p:text-on-surface-variant prose-p:leading-relaxed
    prose-a:text-primary prose-a:no-underline hover:prose-a:underline
    prose-table:text-sm
    prose-th:text-left prose-th:font-bold prose-th:bg-surface-container-low prose-th:p-3
    prose-td:p-3 prose-td:border-b prose-td:border-surface-container
    prose-blockquote:bg-primary-container/10 prose-blockquote:border-l-4 prose-blockquote:border-primary-container prose-blockquote:rounded-r-lg prose-blockquote:py-3 prose-blockquote:px-4 prose-blockquote:not-italic
    prose-strong:text-on-surface
    prose-li:text-on-surface-variant
  ">
    <Fragment set:html={html} />
  </article>
</Base>
