---
import Base from '../../layouts/Base.astro';

const sections = [
  {
    title: 'Getting Started',
    guides: [
      { slug: 'first-trip', title: 'Your First Costco Trip', description: 'Membership tiers, what to buy first, pro tips for newbies', icon: 'shopping_cart' },
      { slug: 'meal-plans', title: 'Weekly Meal Plans', description: 'Feed a family of 4 for a week — three budget tiers', icon: 'calendar_month' },
      { slug: 'rotisserie-chicken', title: 'One Chicken, Five Meals', description: 'Break down a rotisserie chicken and stretch it across the week', icon: 'set_meal' },
      { slug: 'by-country', title: 'Costco by Country', description: "What's at your local Costco — all 14 countries mapped", icon: 'public' },
    ],
  },
  {
    title: 'Reference',
    guides: [
      { slug: 'cost-index', title: 'Cost Index', description: 'Every recipe ranked by cost-per-serving', icon: 'payments' },
      { slug: 'dietary', title: 'Dietary Index', description: 'Which recipes are vegetarian, gluten-free, or dairy-free', icon: 'eco' },
      { slug: 'seasonal', title: 'Seasonal Guide', description: 'What ingredients to buy by season — produce, meat deals, bakery rotations', icon: 'sunny' },
      { slug: 'whats-in-season', title: "What's In Season", description: 'What to cook this month — recipes matched to current Costco offerings', icon: 'trending_up' },
      { slug: 'freezer-guide', title: 'Freezer Guide', description: 'What to freeze, how long it lasts, and how to thaw it', icon: 'ac_unit' },
      { slug: 'by-ingredient', title: 'Recipes by Ingredient', description: 'Find recipes by what protein or ingredient you have', icon: 'grocery' },
    ],
  },
  {
    title: 'Special Occasions',
    guides: [
      { slug: 'party-planning', title: 'Party Planning', description: 'How to feed 10, 25, or 50 people without losing your mind', icon: 'celebration' },
      { slug: 'holidays', title: 'Holiday & Event Collections', description: 'Thanksgiving, Super Bowl, Summer BBQ, Holiday Baking, Back to School', icon: 'cake' },
    ],
  },
];
---

<Base title="Guides — bulk.recipes" description="Tips, tricks, and strategies for getting the most out of your Costco haul.">
  <div class="py-8">
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-6xl font-headline font-black tracking-tight mb-4">
        The <span class="text-primary">Playbook</span>
      </h1>
      <p class="text-lg text-on-surface-variant font-body max-w-2xl mx-auto">
        Tips, tricks, and strategies for getting the most out of your Costco haul. From your first trip to holiday party planning.
      </p>
    </div>

    {sections.map(section => (
      <div class="mb-12">
        <h2 class="font-headline text-2xl font-extrabold tracking-tight mb-6 border-b-4 border-primary inline-block pb-1">
          {section.title}
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {section.guides.map(guide => (
            <a href={`/guides/${guide.slug}`} class="group block">
              <div class="bg-surface-container-lowest rounded-xl p-6 shadow-[0_8px_32px_rgba(47,47,47,0.04)] hover:-translate-y-1 hover:shadow-[0_12px_40px_rgba(47,47,47,0.08)] transition-all duration-300 h-full">
                <span class="material-symbols-outlined text-3xl text-primary mb-4 block" aria-hidden="true">{guide.icon}</span>
                <h3 class="font-headline font-bold text-lg mb-2 group-hover:text-primary transition-colors">
                  {guide.title}
                </h3>
                <p class="text-sm text-on-surface-variant leading-relaxed">
                  {guide.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    ))}

    <div class="mt-8 p-6 bg-surface-container-low rounded-xl">
      <h2 class="font-headline font-bold text-lg mb-3">See Also</h2>
      <div class="flex flex-wrap gap-4">
        <a href="/products" class="text-primary font-bold hover:underline">Costco Groceries</a>
        <a href="/prepared" class="text-primary font-bold hover:underline">Prepared Foods</a>
        <a href="/recipes" class="text-primary font-bold hover:underline">All Recipes</a>
      </div>
    </div>
  </div>
</Base>
