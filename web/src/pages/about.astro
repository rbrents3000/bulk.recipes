---
import Base from '../layouts/Base.astro';
---

<Base title="About — bulk.recipes" description="The unofficial field guide to cooking with Costco groceries.">
  <div class="max-w-3xl mx-auto py-16 text-center">
    <h1 class="text-4xl md:text-6xl font-headline font-black tracking-tight mb-6">
      About <span class="text-primary italic">bulk</span>.recipes
    </h1>

    <p class="text-xl text-on-surface-variant leading-relaxed mb-8">
      The unofficial field guide to feeding yourself (and probably 12 other people) with Costco groceries. No web app drama. Just recipes, prepared food menus, and guides — all open source.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 text-left">
      <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_8px_32px_rgba(47,47,47,0.04)]">
        <span class="material-symbols-outlined text-primary text-3xl mb-3">restaurant</span>
        <h3 class="font-headline font-bold text-lg mb-2">181 Recipes</h3>
        <p class="text-sm text-on-surface-variant">Every recipe has a Costco shopping list and cost-per-serving breakdown.</p>
      </div>
      <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_8px_32px_rgba(47,47,47,0.04)]">
        <span class="material-symbols-outlined text-primary text-3xl mb-3">public</span>
        <h3 class="font-headline font-bold text-lg mb-2">14 Countries</h3>
        <p class="text-sm text-on-surface-variant">Food court, deli, and bakery menus from every country where Costco operates.</p>
      </div>
      <div class="bg-surface-container-lowest p-6 rounded-xl shadow-[0_8px_32px_rgba(47,47,47,0.04)]">
        <span class="material-symbols-outlined text-primary text-3xl mb-3">code</span>
        <h3 class="font-headline font-bold text-lg mb-2">Open Source</h3>
        <p class="text-sm text-on-surface-variant">Everything lives on GitHub. Contribute recipes, fix prices, or add your local Costco finds.</p>
      </div>
    </div>

    <div class="space-y-4">
      <a href="https://github.com/rbrents3000/bulk.recipes" target="_blank" rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-4 bg-primary text-on-primary font-headline font-bold text-lg rounded-full hover:scale-105 transition-transform shadow-[0_8px_32px_rgba(186,0,39,0.3)]">
        <span class="material-symbols-outlined">code</span>
        View on GitHub
      </a>
      <p class="text-sm text-on-surface-variant">
        Not affiliated with Costco Wholesale Corporation. Just fans.
      </p>
    </div>
  </div>
</Base>
