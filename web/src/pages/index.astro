---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import HeroSearch from '../components/HeroSearch.astro';
import CountryPicker from '../components/CountryPicker.astro';
import MonthlyPicks from '../components/MonthlyPicks.astro';
import BakeryStrip from '../components/BakeryStrip.astro';
import CategoryBento from '../components/CategoryBento.astro';
import InternationalSpotlight from '../components/InternationalSpotlight.astro';
import NewThisMonth from '../components/NewThisMonth.astro';

const recipes = await getCollection('recipes');

// Category counts for bento grid
const categoryCounts: Record<string, number> = {};
for (const r of recipes) {
  const cat = r.data.category;
  categoryCounts[cat] = (categoryCounts[cat] || 0) + 1;
}

// Copycat total
const copycatCount = recipes.filter(r => r.data.category.startsWith('costco-copycats')).length;
categoryCounts['costco-copycats'] = copycatCount;

// Dynamic month-based picks
const month = new Date().getMonth(); // 0=Jan, 11=Dec
const seasonCategories: Record<string, string[]> = {
  winter: ['slow-cooker', 'soups', 'desserts', 'feeding-a-crowd'],
  spring: ['salads', 'grilling', 'appetizers', 'drinks'],
  summer: ['grilling', 'salads', 'drinks', 'snacks'],
  fall: ['slow-cooker', 'soups', 'desserts', 'feeding-a-crowd'],
};
const season = month <= 1 || month === 11 ? 'winter' : month <= 4 ? 'spring' : month <= 7 ? 'summer' : 'fall';
const seasonCats = seasonCategories[season];

// Prioritize impressive hero categories, exclude drinks/snacks from homepage
const heroCats = ['weeknight-dinners', 'grilling', 'feeding-a-crowd', 'rotisserie-chicken', 'meal-prep', 'slow-cooker'];
const seasonalPicks = recipes
  .filter(r => heroCats.includes(r.data.category) || seasonCats.includes(r.data.category))
  .filter(r => !['drinks', 'snacks'].includes(r.data.category))
  .sort((a, b) => {
    // Prefer hero categories, then by servings (crowd-pleasers first)
    const aHero = heroCats.includes(a.data.category) ? 0 : 1;
    const bHero = heroCats.includes(b.data.category) ? 0 : 1;
    if (aHero !== bHero) return aHero - bHero;
    return (parseInt(b.data.servings) || 4) - (parseInt(a.data.servings) || 4);
  })
  .slice(0, 8)
  .map(r => ({
    title: r.data.title,
    slug: r.id,
    cost: r.data.cost,
    cost_unit: r.data.cost_unit,
    cook: r.data.cook,
    servings: r.data.servings,
    category: r.data.category,
  }));

// New this month: latest copycats (the most recently added category)
const newRecipes = recipes
  .filter(r => r.data.category === 'costco-copycats/bakery' || r.data.category === 'costco-copycats/deli')
  .sort((a, b) => b.data.cost - a.data.cost)
  .slice(0, 6)
  .map(r => ({
    title: r.data.title,
    slug: r.id,
    description: r.data.description,
    cost: r.data.cost,
    category: r.data.category,
    cost_unit: r.data.cost_unit,
  }));
---

<Base title="bulk.recipes — Cook with Costco">
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "bulk.recipes",
    "url": "https://bulk.recipes",
    "description": `The unofficial field guide to cooking with Costco groceries. ${recipes.length} recipes with Costco shopping lists and cost-per-serving breakdowns.`,
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://bulk.recipes/recipes?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  })} />
  <HeroSearch recipeCount={recipes.length} />
  <CountryPicker />
  <MonthlyPicks recipes={seasonalPicks} />
  <BakeryStrip />
  <CategoryBento categoryCounts={categoryCounts} />
  <InternationalSpotlight />
  <NewThisMonth recipes={newRecipes} />
</Base>
