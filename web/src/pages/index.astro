---
import Base from '../layouts/Base.astro';
---

<Base title="bulk.recipes — Cook with Costco">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center gap-8">
    <h1 class="text-5xl md:text-7xl font-headline font-black tracking-tight text-on-surface">
      <span class="text-primary italic">bulk</span>.recipes
    </h1>
    <p class="text-xl md:text-2xl font-body text-on-surface-variant max-w-2xl">
      The unofficial field guide to feeding yourself (and probably 12 other people) with Costco groceries.
    </p>
    <div class="flex flex-wrap justify-center gap-4 mt-4">
      <a href="/recipes" class="px-8 py-4 bg-primary text-on-primary font-headline font-bold text-lg rounded-full hover:scale-105 transition-transform shadow-[0_8px_32px_rgba(186,0,39,0.3)]">
        Browse 181 Recipes
      </a>
      <a href="/prepared" class="px-8 py-4 bg-secondary-container text-on-secondary-container font-headline font-bold text-lg rounded-full hover:scale-105 transition-transform">
        Explore 14 Countries
      </a>
    </div>
    <p class="text-sm text-on-surface-variant font-body mt-8">
      Coming soon — full site with search, filtering, recipe scaling, and more.
      <br />
      <a href="https://github.com/rbrents3000/bulk.recipes" class="text-primary hover:underline" target="_blank" rel="noopener">Browse on GitHub →</a>
    </p>
  </div>
</Base>
