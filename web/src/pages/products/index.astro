---
import { readFileSync } from 'node:fs';
import { join } from 'node:path';
import { marked } from 'marked';
import Base from '../../layouts/Base.astro';

const md = readFileSync(join(process.cwd(), '..', 'products', 'README.md'), 'utf-8');
const html = marked(md) as string;
---

<Base title="Costco Groceries — bulk.recipes" description="The raw ingredients you buy at Costco — meat, seafood, dairy, pantry staples, frozen, produce, and Kirkland Signature hits.">
  <article class="max-w-4xl mx-auto py-8 prose prose-lg max-w-none
    prose-headings:font-headline prose-headings:tracking-tight
    prose-h1:text-4xl prose-h1:font-black
    prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-10
    prose-p:text-on-surface-variant prose-p:leading-relaxed
    prose-a:text-primary prose-a:no-underline hover:prose-a:underline
    prose-table:text-sm
    prose-th:text-left prose-th:font-bold prose-th:bg-surface-container-low prose-th:p-3
    prose-td:p-3 prose-td:border-b prose-td:border-surface-container
    prose-strong:text-on-surface
    prose-li:text-on-surface-variant
  ">
    <Fragment set:html={html} />
  </article>
</Base>
