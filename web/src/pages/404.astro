---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found — bulk.recipes" description="The page you're looking for doesn't exist. Browse our Costco recipes instead.">
  <div class="flex flex-col items-center justify-center text-center py-24">
    <h1 class="text-6xl font-headline font-black tracking-tight text-on-surface mb-4">404</h1>
    <p class="text-xl text-on-surface-variant font-medium mb-8">This page doesn't exist — maybe it was a limited-time item.</p>
    <div class="flex gap-4">
      <a href="/" class="px-6 py-3 bg-primary text-white rounded-full font-bold hover:bg-primary/90 transition-colors">
        Go Home
      </a>
      <a href="/recipes" class="px-6 py-3 bg-surface-container-highest rounded-full font-bold hover:bg-outline-variant transition-colors">
        Browse Recipes
      </a>
    </div>
  </div>
</Base>
