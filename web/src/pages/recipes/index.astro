---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import RecipeBrowser from '../../components/RecipeBrowser';
import { extractTag } from '../../data/ingredientTags';

const recipes = await getCollection('recipes');

// Serialize recipe data for the client island
const recipeData = recipes.map(r => ({
  id: r.id,
  title: r.data.title,
  description: r.data.description,
  card_description: r.data.card_description,
  cost: r.data.cost,
  cost_unit: r.data.cost_unit,
  prep: r.data.prep,
  cook: r.data.cook,
  servings: r.data.servings,
  category: r.data.category,
  vegetarian: r.data.vegetarian,
  gluten_free: r.data.gluten_free,
  dairy_free: r.data.dairy_free,
  ingredientTags: [...new Set(
    (r.data.costco_ingredients || [])
      .map((ing: string) => extractTag(ing))
      .filter((t): t is string => t !== null)
  )],
}));

// Unique categories for the dropdown
const categories = [...new Set(recipes.map(r => r.data.category))].sort();

// Top ingredient tags by frequency
const tagCounts = new Map<string, number>();
recipeData.forEach(r => r.ingredientTags.forEach(t => {
  tagCounts.set(t, (tagCounts.get(t) || 0) + 1);
}));
const topTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .slice(0, 20)
  .map(([tag]) => tag);
---

<Base title="Browse Recipes — bulk.recipes" description={`Search, filter, and sort ${recipes.length} Costco recipes by cost, cook time, diet, and ingredient.`}>
  <!-- Skeleton shown until Preact island hydrates -->
  <div id="recipe-skeleton" class="py-8">
    <div class="flex flex-col md:flex-row gap-8 lg:gap-12">
      <aside class="hidden md:block w-56 lg:w-64 space-y-6">
        <div class="h-14 bg-surface-container-highest rounded-xl animate-pulse"></div>
        <div class="h-8 w-32 bg-surface-container-highest rounded animate-pulse"></div>
        <div class="h-14 bg-surface-container-highest rounded-xl animate-pulse"></div>
        <div class="h-14 bg-surface-container-highest rounded-xl animate-pulse"></div>
      </aside>
      <div class="flex-1 space-y-8">
        <div class="h-12 w-64 bg-surface-container-highest rounded animate-pulse"></div>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          {Array.from({ length: 6 }).map((_, i) => (
            <div key={i} class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_8px_32px_rgba(47,47,47,0.04)]">
              <div class="p-3"><div class="h-44 md:h-56 bg-surface-container rounded-lg animate-pulse"></div></div>
              <div class="px-6 pb-6 pt-2 space-y-3">
                <div class="h-5 w-3/4 bg-surface-container-highest rounded animate-pulse"></div>
                <div class="h-4 w-full bg-surface-container-highest rounded animate-pulse"></div>
                <div class="h-3 w-1/2 bg-surface-container-highest rounded animate-pulse"></div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
  <RecipeBrowser client:only="preact" recipes={recipeData} categories={categories} ingredientTags={topTags} />
</Base>
