---
import Base from '../../layouts/Base.astro';
---

<Base title="Recipes — bulk.recipes">
  <div class="flex flex-col items-center justify-center min-h-[40vh] text-center gap-6 py-16">
    <h1 class="text-4xl md:text-5xl font-headline font-black tracking-tight">
      Recipes
    </h1>
    <p class="text-lg text-on-surface-variant font-body max-w-xl">
      181 homemade recipes built around Costco ingredients. Search, filter, and find what to cook tonight.
    </p>
    <p class="text-sm text-on-surface-variant">Coming soon. <a href="https://github.com/rbrents3000/bulk.recipes/tree/main/recipes" class="text-primary hover:underline">Browse on GitHub →</a></p>
  </div>
</Base>
