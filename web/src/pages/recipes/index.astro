---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import RecipeBrowser from '../../components/RecipeBrowser';

const recipes = await getCollection('recipes');

// Serialize recipe data for the client island
const recipeData = recipes.map(r => ({
  id: r.id,
  title: r.data.title,
  description: r.data.description,
  cost: r.data.cost,
  cost_unit: r.data.cost_unit,
  prep: r.data.prep,
  cook: r.data.cook,
  servings: r.data.servings,
  category: r.data.category,
  vegetarian: r.data.vegetarian,
  gluten_free: r.data.gluten_free,
  dairy_free: r.data.dairy_free,
}));

// Unique categories for the dropdown
const categories = [...new Set(recipes.map(r => r.data.category))].sort();
---

<Base title="Browse Recipes — bulk.recipes" description="Search, filter, and sort 181 Costco recipes by cost, cook time, diet, and ingredient.">
  <RecipeBrowser client:load recipes={recipeData} categories={categories} />
</Base>
