---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import RecipeCard from '../../components/RecipeCard.astro';
import ServingsScaler from '../../components/ServingsScaler';
import RecipeSchema from '../../components/RecipeSchema.astro';
import IngredientChecklist from '../../components/IngredientChecklist';
import IngredientChips from '../../components/IngredientChips.astro';
import StorageBox from '../../components/StorageBox.astro';
import InstructionSteps from '../../components/InstructionSteps.astro';
import LeftoverIdeas from '../../components/LeftoverIdeas.astro';
import { extractTag } from '../../data/ingredientTags';
import { getCategoryImage } from '../../data/categoryImages';
import ShareBar from '../../components/ShareBar';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map(recipe => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const {
  title, description, prep, cook, servings, cost, cost_unit, category,
  vegetarian, gluten_free, dairy_free,
  costco_ingredients, other_ingredients, instructions: recipeInstructions,
  storage, leftover_ideas
} = recipe.data;

const costDisplay = cost_unit === 'serving' ? `$${cost.toFixed(2)}/serving` : `$${cost.toFixed(2)}/${cost_unit}`;

// Copycat callout — link back to the prepared food page
const isCopycat = category.startsWith('costco-copycats/');
const copycatSection = isCopycat ? category.split('/')[1] : null;
const copycatTab = copycatSection === 'deli' ? 'deli'
  : copycatSection === 'bakery' ? 'bakery'
  : copycatSection === 'food-court' ? 'food-court'
  : copycatSection === 'international' ? 'deli'
  : null;
const copycatLabel = copycatSection === 'deli' ? 'Deli & Prepared Foods'
  : copycatSection === 'bakery' ? 'Bakery'
  : copycatSection === 'food-court' ? 'Food Court'
  : copycatSection === 'international' ? 'International Flavors'
  : null;

// Hero image
const recipeSlug = recipe.id.split('/').pop();
const recipeImage = `/assets/recipes/${recipeSlug}.webp`;
const categoryImage = getCategoryImage(category);

// Keywords for schema
const keywords: string[] = [];
if (category.includes('costco-copycats')) keywords.push('costco copycat');
keywords.push(category.split('/').pop()?.replace(/-/g, ' ') || '');
if (vegetarian) keywords.push('vegetarian');
if (gluten_free) keywords.push('gluten-free');
if (dairy_free) keywords.push('dairy-free');
keywords.push('costco', 'bulk cooking');

// Related recipes — scored by ingredient overlap + category bonus
const allRecipes = await getCollection('recipes');
const currentTags = new Set(
  (costco_ingredients || [])
    .map((ing: string) => extractTag(ing))
    .filter((t): t is string => t !== null)
);

const related = currentTags.size > 0
  ? allRecipes
      .filter(r => r.id !== recipe.id)
      .map(r => {
        const rTags = new Set(
          (r.data.costco_ingredients || [])
            .map((ing: string) => extractTag(ing))
            .filter((t): t is string => t !== null)
        );
        const shared = [...currentTags].filter(t => rTags.has(t)).length;
        const catBonus = r.data.category === category ? 2 : 0;
        return { recipe: r, score: shared + catBonus };
      })
      .filter(r => r.score > 0)
      .sort((a, b) => b.score - a.score)
      .slice(0, 4)
      .map(r => r.recipe)
  : allRecipes
      .filter(r => r.data.category === category && r.id !== recipe.id)
      .slice(0, 4);

// Final fallback: if no related found, pick random recipes
if (related.length === 0) {
  related = allRecipes
    .filter(r => r.id !== recipe.id)
    .sort(() => 0.5 - Math.random())
    .slice(0, 4);
}
---

<Base title={`${title} — bulk.recipes`} description={description} ogImage={`/og/${recipe.id}.png`}>
  <RecipeSchema
    title={title} description={description} prep={prep} cook={cook}
    servings={servings} cost={cost} costUnit={cost_unit} category={category}
    slug={recipe.id} ingredients={[...costco_ingredients, ...other_ingredients]}
    instructions={recipeInstructions} keywords={keywords.join(', ')}
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://bulk.recipes/" },
      { "@type": "ListItem", "position": 2, "name": category.split('/').pop()?.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase()) || "Recipes", "item": `https://bulk.recipes/recipes/${category}` },
      { "@type": "ListItem", "position": 3, "name": title }
    ]
  })} />

  <article class="max-w-6xl mx-auto py-8" data-pagefind-body>
    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-1.5 text-sm text-on-surface-variant flex-wrap">
        <li><a href="/" class="hover:text-primary transition-colors">Home</a></li>
        <li aria-hidden="true" class="text-outline-variant">/</li>
        <li><a href="/recipes" class="hover:text-primary transition-colors">Recipes</a></li>
        <li aria-hidden="true" class="text-outline-variant">/</li>
        <li><a href={`/recipes?category=${category}`} class="hover:text-primary transition-colors">{category.split('/').pop()?.replace(/-/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}</a></li>
        <li aria-hidden="true" class="text-outline-variant">/</li>
        <li class="font-bold text-on-surface truncate max-w-[200px]" aria-current="page">{title}</li>
      </ol>
    </nav>

    <!-- Hero -->
    <header class="reveal mb-10">
      <div class="mb-4">
        <span class="inline-flex items-center gap-2 px-4 py-1.5 bg-secondary-container text-on-secondary-container rounded-full text-xs font-bold uppercase tracking-wider">
          {category.replace(/[-/]/g, ' ').replace(/\b\w/g, (c: string) => c.toUpperCase())}
        </span>
      </div>

      <h1 class="text-4xl md:text-6xl font-headline font-extrabold tracking-tight text-primary leading-tight mb-4">
        {title}
      </h1>

      <p class="text-xl md:text-2xl text-on-surface-variant font-medium italic mb-6">
        "{description}"
      </p>

      <!-- Hero image -->
      <div class="rounded-xl overflow-hidden shadow-lg mb-6">
        <img
          src={recipeImage}
          alt={title}
          class="w-full max-h-[250px] md:max-h-[400px] object-cover"
          loading="lazy"
          data-fallback={categoryImage}
        />
      </div>

      <!-- Metadata bar -->
      <div class="grid grid-cols-1 min-[400px]:grid-cols-2 gap-4 p-4 md:flex md:flex-wrap md:gap-4 md:p-6 bg-surface-container-low rounded-xl">
        <div class="flex flex-col gap-1 md:pr-6 md:border-r md:border-outline-variant/20">
          <span class="text-xs uppercase font-bold text-on-surface-variant tracking-widest">Prep</span>
          <span class="text-lg font-bold">{prep}</span>
        </div>
        <div class="flex flex-col gap-1 md:pr-6 md:border-r md:border-outline-variant/20">
          <span class="text-xs uppercase font-bold text-on-surface-variant tracking-widest">Cook</span>
          <span class="text-lg font-bold">{cook}</span>
        </div>
        <div class="md:pr-6 md:border-r md:border-outline-variant/20">
          <ServingsScaler
            client:visible
            baseServings={parseInt(servings) || 4}
            baseCost={cost}
            costUnit={cost_unit}
          />
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-xs uppercase font-bold text-on-surface-variant tracking-widest">Cost</span>
          <span class="text-lg font-bold text-tertiary">{costDisplay}</span>
        </div>
      </div>

      <!-- Copycat callout -->
      {isCopycat && copycatTab && (
        <div class="flex items-center gap-3 p-4 bg-tertiary-container/40 border border-tertiary/20 rounded-xl mt-6">
          <span class="material-symbols-outlined text-tertiary text-2xl">storefront</span>
          <p class="text-sm text-on-surface">
            <strong>Costco Copycat</strong> — This is a homemade version of the Costco {copycatLabel} item.
            <a href={`/prepared/us#${copycatTab}`} class="text-primary font-bold hover:underline ml-1">See it in store →</a>
          </p>
        </div>
      )}

      <!-- Diet badges -->
      {(vegetarian || gluten_free || dairy_free) && (
        <div class="flex gap-2 mt-4">
          {vegetarian && <span class="text-xs px-3 py-1 bg-green-100 text-green-800 rounded-full font-bold">Vegetarian</span>}
          {gluten_free && <span class="text-xs px-3 py-1 bg-amber-100 text-amber-800 rounded-full font-bold">Gluten-Free</span>}
          {dairy_free && <span class="text-xs px-3 py-1 bg-blue-100 text-blue-800 rounded-full font-bold">Dairy-Free</span>}
        </div>
      )}
      <ShareBar
        client:idle
        url={`https://bulk.recipes/recipes/${recipe.id}`}
        title={title}
        description={description}
        image={`https://bulk.recipes/og/${recipe.id}.png`}
      />
    </header>

    <!-- Storage callout — shown above instructions on desktop for meal planners -->
    {storage && (
      <div class="reveal hidden lg:block mb-8">
        <StorageBox storage={storage} />
      </div>
    )}

    <!-- Asymmetric Grid: Sidebar + Main -->
    <div class="reveal grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">

      <!-- Sidebar (4 cols) -->
      <aside class="lg:col-span-4 space-y-8">
        {costco_ingredients.length > 0 && (
          <IngredientChecklist client:visible items={costco_ingredients} recipeId={recipe.id} />
        )}

        {other_ingredients.length > 0 && (
          <IngredientChips items={other_ingredients} />
        )}

        {storage && (
          <div class="lg:hidden">
            <StorageBox storage={storage} />
          </div>
        )}
      </aside>

      <!-- Main Content (8 cols) -->
      <div class="lg:col-span-8 space-y-12">
        {recipeInstructions.length > 0 && (
          <InstructionSteps steps={recipeInstructions} />
        )}

        {leftover_ideas.length > 0 && (
          <LeftoverIdeas ideas={leftover_ideas} />
        )}
      </div>
    </div>
  </article>

  <!-- Related Recipes -->
  {related.length > 0 && (
    <section aria-label="Related recipes" class="reveal max-w-6xl mx-auto mt-16 mb-8">
      <div class="flex justify-between items-end mb-8">
        <div>
          <h2 class="text-3xl font-headline font-black tracking-tight">More Bulk Brilliance</h2>
          <p class="text-on-surface-variant font-medium">Keep the pantry full and the wallet happy.</p>
        </div>
        <a href="/recipes" class="px-6 py-2 bg-surface-container-highest rounded-full text-sm font-bold hover:bg-outline-variant transition-colors">
          View All
        </a>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {related.map(r => (
          <RecipeCard
            title={r.data.title}
            description={r.data.description}
            cost={r.data.cost}
            cost_unit={r.data.cost_unit}
            prep={r.data.prep}
            cook={r.data.cook}
            servings={r.data.servings}
            category={r.data.category}
            vegetarian={r.data.vegetarian}
            gluten_free={r.data.gluten_free}
            dairy_free={r.data.dairy_free}
            slug={r.id}
          />
        ))}
      </div>
    </section>
  )}
</Base>
